# Airflow core settings
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Fernet key for encrypting connections/passwords (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIRFLOW__CORE__FERNET_KEY=

# Secret key for Flask web server (generate with: python -c "import secrets; print(secrets.token_hex(16))")
AIRFLOW__WEBSERVER__SECRET_KEY=

# Airflow image version
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.1

# Postgres settings
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Kubernetes namespace for KubernetesPodOperator tasks (used when deploying to K8s)
AIRFLOW__KUBERNETES__NAMESPACE=airflow

# ---------------------------------------------------------------------------
# Remote Airflow instance settings (used by `make remote-*` targets)
# ---------------------------------------------------------------------------
# Base URL of the remote Airflow webserver (no trailing slash)
AIRFLOW_REMOTE_URL=https://your-airflow-instance.example.com

# Credentials for the Airflow REST API
AIRFLOW_REMOTE_USERNAME=admin
AIRFLOW_REMOTE_PASSWORD=

# SSH access for syncing DAG files to the remote host
# Leave AIRFLOW_REMOTE_SSH_HOST empty to skip rsync and rely on a shared volume
AIRFLOW_REMOTE_SSH_HOST=
AIRFLOW_REMOTE_SSH_USER=ubuntu
AIRFLOW_REMOTE_SSH_KEY=~/.ssh/id_rsa
# Absolute path to the dags folder on the remote host
AIRFLOW_REMOTE_DAG_FOLDER=/opt/airflow/dags
